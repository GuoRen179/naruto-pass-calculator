.page {
  min-height: 100vh;
  padding: 32rpx;
}

.panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 36rpx;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 48rpx rgba(29, 37, 39, 0.12);
}

.eyebrow {
  color: #b33a2d;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  color: #1d2527;
  font-size: 44rpx;
  font-weight: 800;
}

.hint {
  color: #5d534a;
  font-size: 28rpx;
  line-height: 1.7;
}
